{
  "servers": {
    "search-prime": {
      "command": "npx",
      "args": ["-y", "@zai-mcp/web-search-prime"],
      "cacheTtlSeconds": 86400,
      "negativeCacheTtlSeconds": 300
    },
    "web-reader": {
      "command": "npx",
      "args": ["-y", "@zai-mcp/web-reader"],
      "cacheTtlSeconds": 21600,
      "negativeCacheTtlSeconds": 600
    },
    "zread": {
      "command": "npx",
      "args": ["-y", "@zai-mcp/zread"],
      "cacheTtlSeconds": 3600
    },
    "http-server": {
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "cacheTtlSeconds": 86400
    },
    "adaptive-server": {
      "command": "npx",
      "args": ["-y", "@example/server"],
      "cacheTtlSeconds": 43200,
      "adaptiveTtl": true,
      "cacheTtlRange": { "min": 3600, "max": 86400 }
    }
  },
  "cache": {
    "path": "~/.mcp-cache-proxy/cache.db",
    "maxSizeBytes": 104857600,
    "maxEntrySizeBytes": 10485760,
    "defaultTtlSeconds": 43200,
    "negativeCacheTtlSeconds": 300,
    "staleWhileRevalidateSeconds": 0
  },
  "mode": "whitelist",
  "extendGlobal": true
}
